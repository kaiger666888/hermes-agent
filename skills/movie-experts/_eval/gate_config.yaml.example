# Phase 30 Eval Gate — default configuration.
#
# Copy this file to gate_config.yaml (same directory) and tune for your
# operator-local thresholds. The gate_config.yaml copy is gitignored if
# it diverges from this example — keep your secrets/local tuning out of git.
#
# Field reference (per 30-CONTEXT.md Gate CLI Surface):
#   delta_threshold      Mean composite score drop allowed (4-point rubric).
#                        Patches whose mean drops more than this below
#                        baseline are REJECTED (verdict=fail_mean, exit 1).
#                        Range [0.0, 5.0]. Default 0.3.
#   per_prompt_threshold Max single-prompt regression allowed. Patches with
#                        ANY prompt dropping more than this are REJECTED
#                        (verdict=fail_regression, exit 2), even if the
#                        mean is acceptable. Range [0.0, 5.0]. Default 1.0.
#   min_prompts          Validity floor. Patches scored on fewer than this
#                        many valid prompts are REJECTED as inconclusive
#                        (exit 3). >= 1. Default 5.
#   ab_positions         Position-swap rounds. 1 = no swap (single ordering);
#                        2 = swap baseline/candidate (double-blind, recommended).
#                        Must be in {1, 2}. Default 2.
#   judge_model          Override the default judge model from runner config.
#                        Default "claude-sonnet-4-6".
#
# CLI flags override YAML values, which override these defaults:
#   --threshold-delta, --per-prompt-threshold, --min-prompts,
#   --ab-positions, --judge-model

delta_threshold: 0.3
per_prompt_threshold: 1.0
min_prompts: 5
ab_positions: 2
judge_model: "claude-sonnet-4-6"
